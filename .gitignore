# dependencies
/node_modules

# build output
/build
*.tsbuildinfo

# logs
*.log
npm-debug.log*

# local env files
.env
.env*.local

# os / editor
.DS_Store
*.pem
.eslintcache

# runtime per-guild data (keep the global lists plus the example templates)
/data/*
!/data/global/
/data/global/*
!/data/global/swears.json
!/data/global/swears.example.json
!/data/global/insults.json
!/data/global/insults.example.json
!/data/global/slur_responses.example.json
# slurs.json (real slurs) and slur_responses.json (your own replies) stay local;
# the bot falls back to a built-in default, and the .example files are the templates.
!/data/global/slurs.example.json
