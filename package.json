{
  "name": "reactionbot",
  "version": "2.0.0",
  "license": "MIT",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "tsc && tsc-alias && node build/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint \"{src,scripts}/**/*.{js,ts}\" --fix",
    "format": "prettier --write \"**/*.{js,ts,md,json,yml,yaml}\"",
    "smoke": "tsx scripts/smoke-test.ts",
    "prepare": "simple-git-hooks"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wobkobi/reactionBot.git"
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/wobkobi/reactionBot/issues"
  },
  "homepage": "https://github.com/wobkobi/reactionBot#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^63.0.2",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "simple-git-hooks": "^2.13.1",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "dependencies": {
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=7.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "pre-push": "npm run build && npm run smoke"
  },
  "lint-staged": {
    "**/*.{js,ts}": [
      "prettier --write",
      "eslint --max-warnings=0"
    ],
    "**/*.{json,md,yml,yaml}": "prettier --write"
  }
}
